// OPTIONAL - Requires Entra ID P1 or P2. Free-tier equivalent: native sign-in log
// filtering - see monitoring/sign-in-monitoring.md.

SigninLogs
| where TimeGenerated > ago(24h)
| where ResultType != "0"
| summarize FailedAttempts = count(), FirstAttempt = min(TimeGenerated), LastAttempt = max(TimeGenerated), IPAddresses = make_set(IPAddress) by UserPrincipalName
| where FailedAttempts >= 5
| order by FailedAttempts desc