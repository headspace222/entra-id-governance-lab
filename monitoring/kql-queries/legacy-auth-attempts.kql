// OPTIONAL - Requires Entra ID P1 or P2. Free-tier equivalent: native sign-in log
// filtering by Client app - see monitoring/sign-in-monitoring.md.

SigninLogs
| where TimeGenerated > ago(7d)
| where ClientAppUsed in ("Exchange ActiveSync", "IMAP4", "POP3", "SMTP", "Other clients", "AutoDetect")
| project TimeGenerated, UserPrincipalName, ClientAppUsed, AppDisplayName, IPAddress, ResultType, Location
| order by TimeGenerated desc